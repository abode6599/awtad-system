<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام أوتاد - السيادة المطلقة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        * { font-family: 'Cairo', sans-serif; }
        body { margin: 0; background: #020617; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // --- مكون البطاقة ---
        const InfoModal = ({ info, db, date, onClose }) => {
            if (!info) return null;
            const live = db[date]?.[`${info.pId}:${info.id}`] || { status: "غير مرصود", score: "--", editorName: "نظام أوتاد", editTime: "--" };
            return (
                <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.95)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 4000, backdropFilter: "blur(12px)" }}>
                    <div style={{ background: "#1e293b", padding: "40px", borderRadius: "35px", width: "90%", maxWidth: "450px", textAlign: "center", border: "2px solid #22d3ee" }}>
                        <h3 style={{ color: "#22d3ee" }}>التحقق الرقمي</h3>
                        <p style={{ fontSize: "24px", color: "white" }}>{info.n}</p>
                        <div style={{ textAlign: "right", marginTop: "25px", color: "#94a3b8", background: "#0f172a", padding: "20px", borderRadius: "20px" }}>
                            <p>📌 الحالة: <span style={{ color: "white" }}>{live.status === "present" ? "حاضر ✅" : live.status === "absent" ? "غائب ❌" : "لم يرصد"}</span></p>
                            <p>📊 الدرجة: <span style={{ color: "#22d3ee" }}>{live.score} / 10</span></p>
                            <p style={{ fontSize: "12px" }}>✍️ المسؤول: {live.editorName}</p>
                        </div>
                        <button onClick={onClose} style={{ marginTop: "30px", background: "#ef4444", color: "white", border: "none", padding: "10px 40px", borderRadius: "15px", cursor: "pointer" }}>إغلاق</button>
                    </div>
                </div>
            );
        };

        // --- البيانات الأساسية ---
        const DATA = {
            unit: { name: "مدرسة القاسم بن محمد", chief: "عبدالله العرفه" },
            users: [
                { name: "سلمان الصويلح", id: "111", role: "admin" },
                { name: "معاذ الشنقيطي", id: "222", role: "admin" },
                { name: "عبدالله العرفه", id: "333", role: "admin" },
                { name: "الوليد الحازمي", id: "1158717536", role: "leader" },
                { name: "وضاح الصويلح", id: "1148865378", role: "leader" }
            ],
            platoons: [
                { id: 1, name: "طليعة ١", color: "#f59e0b", leaderId: "1158717536", members: [{ n: "صالح سعيد حبتور", id: "1149916643" }, { n: "عزام حيدر خبراني", id: "1149391128" }, { n: "الوليد فيصل الحازمي", id: "1158717536" }] },
                { id: 4, name: "طليعة ٤", color: "#34d399", leaderId: "1148865378", members: [{ n: "وضاح ماجد الصويلح", id: "1148865378" }, { n: "مبارك مرزوق خميس", id: "1145673271" }] }
            ]
        };

        function App() {
            const [user, setUser] = useState(null);
            const [loginId, setLoginId] = useState("");
            const [date, setDate] = useState(new Date().toISOString().split("T")[0]);
            const [db, setDb] = useState({});
            const [info, setInfo] = useState(null);

            useEffect(() => {
                const saved = localStorage.getItem("awtad_v8_final");
                if (saved) setDb(JSON.parse(saved));
            }, []);

            const handleLogin = () => {
                const found = DATA.users.find(u => u.id === loginId);
                if (found) setUser(found);
                else alert("خطأ في السجل!");
            };

            const updateEntry = (pId, mId, field, val) => {
                const entryKey = `${pId}:${mId}`;
                const newDb = { ...db, [date]: { ...db[date], [entryKey]: { ...(db[date]?.[entryKey] || { status: null, score: 5 }), [field]: val, editorName: user.name, editTime: new Date().toLocaleTimeString('ar-SA') } } };
                setDb(newDb);
                localStorage.setItem("awtad_v8_final", JSON.stringify(newDb));
            };

            if (!user) return (
                <div style={{ height: "100vh", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", color: "white" }}>
                    <h1 style={{ letterSpacing: "5px", color: "#22d3ee" }}>أوتـاد</h1>
                    <input type="password" placeholder="السجل المدني" value={loginId} onChange={e => setLoginId(e.target.value)} style={{ padding: "15px", borderRadius: "10px", textAlign: "center" }} />
                    <button onClick={handleLogin} style={{ marginTop: "20px", padding: "10px 50px", background: "#22d3ee", border: "none", borderRadius: "10px", fontWeight: "bold" }}>دخول</button>
                </div>
            );

            return (
                <div style={{ padding: "20px", color: "white" }}>
                    <header style={{ background: "#1e293b", padding: "20px", borderRadius: "20px", marginBottom: "20px" }}>
                        <h2>{DATA.unit.name}</h2>
                        <p>المحقق: {user.name} 🎖️</p>
                    </header>
                    <input type="date" value={date} onChange={e => setDate(e.target.value)} style={{ width: "100%", padding: "10px", marginBottom: "20px", borderRadius: "10px" }} />
                    {DATA.platoons.map(p => (
                        (user.role === "admin" || p.leaderId === user.id) && (
                            <div key={p.id} style={{ border: `1px solid ${p.color}`, padding: "15px", borderRadius: "20px", marginBottom: "20px" }}>
                                <h3 style={{ color: p.color }}>{p.name}</h3>
                                {p.members.map(m => {
                                    const rec = db[date]?.[`${p.id}:${m.id}`] || { status: null, score: 5 };
                                    return (
                                        <div key={m.id} style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "10px" }}>
                                            <span style={{ flex: 1 }}>{m.n}</span>
                                            <button onClick={() => setInfo({...m, pId: p.id})} style={{background: "none", border: "none", cursor: "pointer"}}>🕵️</button>
                                            <select value={rec.status || ""} onChange={e => updateEntry(p.id, m.id, "status", e.target.value)} style={{ borderRadius: "5px" }}>
                                                <option value="">؟</option>
                                                <option value="present">حاضر</option>
                                                <option value="absent">غائب</option>
                                            </select>
                                            <input type="number" value={rec.score} onChange={e => updateEntry(p.id, m.id, "score", e.target.value)} style={{ width: "40px", textAlign: "center" }} />
                                        </div>
                                    );
                                })}
                            </div>
                        )
                    ))}
                    <InfoModal info={info} db={db} date={date} onClose={() => setInfo(null)} />
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
